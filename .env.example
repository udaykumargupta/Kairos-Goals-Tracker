# Copy to .env and fill in. Load into your shell before running the backend, e.g.:
#   export $(grep -v '^#' .env | xargs)

# From Google Cloud Console → APIs & Services → Credentials → OAuth Client ID (Web)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Any random string of at least 32 characters. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Optional overrides (defaults shown)
# DB_URL=jdbc:postgresql://localhost:5432/kairos
# DB_USERNAME=kairos
# DB_PASSWORD=kairos
# JWT_EXPIRATION_MS=604800000
